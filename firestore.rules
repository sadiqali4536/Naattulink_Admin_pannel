rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // Helper functions
    // =========================================================================

    // Checks whether the caller is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Returns the admin_users document for the caller.
    // Handles both cases:
    //   A) The caller is signed in with their real Firebase account
    //      (developers, super admins who haven't set up a separate web account yet).
    //      → looks up admin_users/{request.auth.uid} directly.
    //   B) The caller is signed in with a web-panel account
    //      (email: {uid}_adm@naattulink.internal).
    //      → looks up web_auth_index/{request.auth.uid} to resolve the original uid,
    //        then reads admin_users/{originalUid}.
    function getAdminData() {
      let uid = request.auth.uid;
      // Case A: direct admin_users entry
      let hasDirect = exists(/databases/$(database)/documents/admin_users/$(uid));
      // Case B: web-panel account → resolve via index
      let hasIndex = !hasDirect
          && exists(/databases/$(database)/documents/web_auth_index/$(uid));
      return hasDirect
          ? get(/databases/$(database)/documents/admin_users/$(uid)).data
          : (hasIndex
              ? get(/databases/$(database)/documents/admin_users/
                  get(/databases/$(database)/documents/web_auth_index/$(uid)).data.originalUid).data
              : null);
    }

    // Is the caller an active admin panel user?
    function isActiveAdmin() {
      let d = getAdminData();
      return isAuthenticated()
          && (
            (d != null && d.status == 'Active' && d.roleLevel >= 45) ||
            request.auth.token.email == 'superadmin@naattulink.com' ||
            request.auth.token.email == 'developer@naattulink.com' ||
            request.auth.token.email == 'developer@nattulinkapp.com'
          );
    }

    // Role level shortcuts
    function callerLevel() {
      return getAdminData().roleLevel;
    }

    function isSuperAdmin() {
      let d = getAdminData();
      return isAuthenticated() && (
        (d != null && d.roleLevel >= 100) ||
        request.auth.token.email == 'superadmin@naattulink.com' ||
        request.auth.token.email == 'developer@naattulink.com' ||
        request.auth.token.email == 'developer@nattulinkapp.com'
      );
    }

    function isAdmin() {
      let d = getAdminData();
      return isAuthenticated() && (
        (d != null && d.roleLevel >= 80) ||
        request.auth.token.email == 'superadmin@naattulink.com' ||
        request.auth.token.email == 'developer@naattulink.com' ||
        request.auth.token.email == 'developer@nattulinkapp.com'
      );
    }

    function isManager() {
      let d = getAdminData();
      return isAuthenticated() && (
        (d != null && d.roleLevel >= 70) ||
        request.auth.token.email == 'superadmin@naattulink.com' ||
        request.auth.token.email == 'developer@naattulink.com' ||
        request.auth.token.email == 'developer@nattulinkapp.com'
      );
    }

    // Checks whether the caller has a specific action on a specific module
    // in their effective permissions (or is privileged).
    // NOTE: Effective permissions are NOT stored in Firestore directly — the
    // permission override merge is done in the client. The backend enforces
    // the role-level hierarchy only, which is the critical security boundary.
    function hasRoleLevel(minLevel) {
      return isActiveAdmin() && callerLevel() >= minLevel;
    }

    // The caller cannot assign/set a roleLevel equal to or above their own.
    function canAssignLevel(targetLevel) {
      return isActiveAdmin() && targetLevel < callerLevel();
    }

    // =========================================================================
    // users collection
    // (normal app users — admin panel reads them to populate dropdowns)
    // =========================================================================
    match /users/{userId} {
      // Authenticated users can always read their own profile
      allow read: if isAuthenticated() && request.auth.uid == userId;

      // Active admin panel users can read all user profiles (for Grant Access)
      allow read: if isActiveAdmin();

      // Users can write their own profile (from the app)
      allow write: if isAuthenticated() && request.auth.uid == userId;

      // Admins can update user status/fields (banning, etc.) — requires Admin+
      allow update: if isAdmin();

      // Admins can delete user profiles — requires Admin+
      allow delete: if isAdmin();
    }

    // =========================================================================
    // admin_users collection
    // The heart of RBAC — who has access to what
    // =========================================================================
    match /admin_users/{targetUid} {
      // Active admins can read all admin_users records
      allow read: if isActiveAdmin();

      // A web-panel auth account (webAuthUid) can read its own linked admin record.
      // This is needed during session load: the web account reads admin_users/{originalUid}
      // to populate the RBAC session.
      allow read: if isAuthenticated()
          && resource.data.webAuthUid == request.auth.uid;

      // Create: Admin+ and the target roleLevel must be below caller's
      // Or: caller is a hardcoded Super Admin/Developer email (to allow initial database setup)
      allow create: if (
        isAdmin()
        && request.resource.data.roleLevel != null
        && canAssignLevel(request.resource.data.roleLevel)
      ) || (
        isAuthenticated()
        && (
          request.auth.token.email == 'superadmin@naattulink.com' ||
          request.auth.token.email == 'developer@naattulink.com' ||
          request.auth.token.email == 'developer@nattulinkapp.com'
        )
      );

      // Update: Admin+ and the updated roleLevel must still be below caller's
      // Or: caller is a hardcoded Super Admin/Developer email
      allow update: if (
        isAdmin()
        && request.resource.data.roleLevel != null
        && canAssignLevel(request.resource.data.roleLevel)
        // Cannot deactivate self
        && targetUid != request.auth.uid
      ) || (
        isAuthenticated()
        && (
          request.auth.token.email == 'superadmin@naattulink.com' ||
          request.auth.token.email == 'developer@naattulink.com' ||
          request.auth.token.email == 'developer@nattulinkapp.com'
        )
      );

      // Super Admin only — soft delete via status is preferred
      allow delete: if isSuperAdmin();
    }

    // =========================================================================
    // roles collection
    // Role definitions — read by all admins, written by Super Admin+
    // =========================================================================
    match /roles/{roleId} {
      // All active admins can read role definitions
      allow read: if isActiveAdmin();

      // Admin+ can create new roles
      // New role level must be strictly below caller's level
      allow create: if isAdmin()
          && request.resource.data.level != null
          && canAssignLevel(request.resource.data.level);

      // Admin+ can update roles they have authority over
      allow update: if isAdmin()
          && resource.data.level < callerLevel()
          && (request.resource.data.level == null || canAssignLevel(request.resource.data.level));

      // Super Admin only can delete role definitions
      allow delete: if isSuperAdmin();
    }

    // =========================================================================
    // modules collection (dynamic module registry)
    // =========================================================================
    match /modules/{moduleId} {
      allow read: if isActiveAdmin();
      allow write: if isSuperAdmin();
    }

    // =========================================================================
    // audit_logs collection (append-only)
    // =========================================================================
    match /audit_logs/{logId} {
      // Admins and above can read audit logs
      allow read: if isAdmin();

      // Any authenticated admin panel user can create logs (backend writes)
      allow create: if isActiveAdmin();

      // NO update or delete — audit logs are immutable
      allow update, delete: if false;
    }

    // =========================================================================
    // workers collection
    // =========================================================================
    match /workers/{workerId} {
      allow read: if isActiveAdmin();
      allow create: if isAuthenticated(); // Workers register via the app
      allow update: if isManager();       // Manager+ can approve/reject
      allow delete: if isAdmin();         // Admin+ can hard-delete
    }

    // =========================================================================
    // bookings collection
    // =========================================================================
    match /bookings/{bookingId} {
      allow read: if isAuthenticated() && (
          request.auth.uid == resource.data.userId ||
          isActiveAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
          request.auth.uid == resource.data.userId || isManager()
      );
      allow delete: if isAdmin();
    }

    // =========================================================================
    // payments collection
    // =========================================================================
    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (
          request.auth.uid == resource.data.userId ||
          isManager()
      );
      allow create: if isAuthenticated();
      // Payments are generally immutable — only Admin+ can update status
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    // =========================================================================
    // notifications collection
    // =========================================================================
    match /notifications/{notifId} {
      allow read: if isAuthenticated();
      allow create: if isManager(); // Manager+ can send notifications
      allow update, delete: if isAdmin();
    }

    // =========================================================================
    // web_auth_index collection
    // Reverse-lookup: web_auth_index/{webAuthUid} → { originalUid, webEmail }
    // Written by the admin panel when granting web access.
    // Read by the session loader to resolve webAuthUid → originalUid.
    // =========================================================================
    match /web_auth_index/{webAuthUid} {
      // A web-panel account can read its own index entry (needed during login
      // to resolve the originalUid for RBAC session loading).
      allow read: if isAuthenticated() && request.auth.uid == webAuthUid;

      // Active admins can read all index entries (for admin panel management)
      allow read: if isActiveAdmin();

      // Only Admin+ can write index entries (done by the admin panel
      // via createWebAdminAccount())
      allow create, update: if isAdmin();

      // Super Admin only can delete index entries
      allow delete: if isSuperAdmin();
    }

    // =========================================================================
    // advertisements collection
    // =========================================================================
    match /advertisements/{adId} {
      allow read: if true;
      allow write: if isActiveAdmin();
    }

    // =========================================================================
    // Deny everything else by default
    // =========================================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
